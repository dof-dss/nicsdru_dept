<?php

/**
 * @file
 * Primary module hooks for Origins File System module.
 */

use Drupal\Core\Database\Query\AlterableInterface;
use Drupal\views\ViewExecutable;

/**
 * Implements hook_views_data().
 */
function dept_fs_views_data() {
  $data = [];

  // We don't define our own data source for Views with a join to media as this
  // presents an issue when trying to use Views filters against the media entity.
  $data['media_duplicates']['table']['group'] = t('Media Duplicates');
  $data['media_duplicates']['table']['provider'] = 'dept_fs';

  // User inner join so we avoid mid mis-matches.
  $data['media_duplicates']['table']['join'] = [
    'media_field_data' => [
      'left_field' => 'mid',
      'field' => 'mid',
      'type' => 'INNER',
    ],
  ];

  $data['media_duplicates']['mid'] = [
    'title' => t('Media ID'),
    'help' => t('The Media entity ID.'),
    'field' => ['id' => 'numeric'],
    'filter' => ['id' => 'numeric'],
    'sort' => ['id' => 'standard'],
    'argument' => ['id' => 'numeric'],
  ];

  $data['media_duplicates']['group_id'] = [
    'title' => t('Group ID'),
    'help' => t('The duplicate group the media entity belongs to.'),
    'field' => [
      'id' => 'numeric',
    ],
    'filter' => [
      'id' => 'numeric',
    ],
    'argument' => [
      'id' => 'numeric',
    ],
    'sort' => [
      'id' => 'standard',
    ],
  ];

  $data['media_duplicates']['checksum'] = [
    'title' => t('Checksum'),
    'help' => t('The file checksum.'),
    'field' => [
      'id' => 'numeric',
    ],
    'filter' => [
      'id' => 'numeric',
    ],
    'argument' => [
      'id' => 'numeric',
    ],
    'sort' => [
      'id' => 'standard',
    ],
  ];

  return $data;
}

/**
 * Implements hook_views_pre_render().
 */
function dept_fs_views_pre_render(ViewExecutable $view) {
  if ($view->id() === 'media_duplicates') {

    $view->element['#attached']['library'][] = 'dept_fs/media-duplicates';
  }
}

/**
 * Implements hook_media_duplicates_checksum_info_alter().
 */
function dept_fs_media_duplicates_checksum_info_alter(array &$providers) {
  // Remove the default file processor as we replace it with our GoFileProcessor.
  unset($providers['file']);
}

/**
 * Implements hook_views_query_alter().
 */
function dept_fs_views_query_alter(ViewExecutable $view, $query) {
  if ($view->id() === 'media_duplicates') {
    $query->addTag('media_duplicates_group_filter');
  }
}

/**
 * Implements hook_query_TAG_alter().
 */
function dept_fs_query_media_duplicates_group_filter_alter(AlterableInterface $query) {
  $database = \Drupal::database();

  // We only want to return rows that have at least more than 1 matching
  // checksum and ignore rows that don't have a checksum value.
  $checksum_query = $database->select('media_field_data', 'mfd')
    ->fields('mfd', ['duplicates_checksum'])
    ->isNotNull('mfd.duplicates_checksum')
    ->groupBy('mfd.duplicates_checksum')
    ->having('COUNT(mfd.mid) > 1');

  $query->condition('media_field_data.duplicates_checksum', $checksum_query, 'IN');
  $query->isNotNull('media_field_data.duplicates_checksum');

}
