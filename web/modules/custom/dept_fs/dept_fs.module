<?php

/**
 * @file
 * Primary module hooks for Origins File System module.
 */

/**
 * Implements hook_views_data().
 */
function dept_fs_views_data() {
  $data = [];

  // We don't define our own data source for Views with a join to media as this
  // presents an issue when trying to use Views filters against the media entity.
  $data['media_duplicates']['table']['group'] = t('Media Duplicates');
  $data['media_duplicates']['table']['provider'] = 'dept_fs';

  // User inner join so we avoid mid mis-matches.
  $data['media_duplicates']['table']['join'] = [
    'media_field_data' => [
      'left_field' => 'mid',
      'field'      => 'mid',
      'type'       => 'INNER',
    ],
  ];

  $data['media_duplicates']['mid'] = [
    'title'    => t('Media ID'),
    'help'     => t('The Media entity ID.'),
    'field'    => ['id' => 'numeric'],
    'filter'   => ['id' => 'numeric'],
    'sort'     => ['id' => 'standard'],
    'argument' => ['id' => 'numeric'],
  ];

  $data['media_duplicates']['group_id'] = [
    'title' => t('Group ID'),
    'help' => t('The duplicate group the media entity belongs to.'),
    'field' => [
      'id' => 'numeric',
    ],
    'filter' => [
      'id' => 'numeric',
    ],
    'argument' => [
      'id' => 'numeric',
    ],
    'sort' => [
      'id' => 'standard',
    ],
  ];

  $data['media_duplicates']['checksum'] = [
    'title' => t('Checksum'),
    'help' => t('The file checksum.'),
    'field' => [
      'id' => 'numeric',
    ],
    'filter' => [
      'id' => 'numeric',
    ],
    'argument' => [
      'id' => 'numeric',
    ],
    'sort' => [
      'id' => 'standard',
    ],
  ];

  return $data;
}
